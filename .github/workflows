
name: Compilar APK desde ZIP
on: [push, workflow_dispatch]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      # 🆕 PASO NUEVO: Descomprime tu ZIP automáticamente
      - name: Descomprimir proyecto
        run: |
          unzip -o ia-local.zip -d .
          ls -la # Verifica que salgan las carpetas app/ etc.

      - name: Configurar Java
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'

      - name: Dar permiso a Gradle
        run: chmod +x gradlew

      - name: Compilar APK
        run: ./gradlew assembleDebug

      - name: Guardar APK listo
        uses: actions/upload-artifact@v4
        with:
          name: APK-Listo
          path: app/build/outputs/apk/debug/app-debug.apk
